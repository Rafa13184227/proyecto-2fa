{
    "name": "proyecto/backend-php",
    "description": "Backend PHP con Slim Framework para sistema 2FA",
    "type": "project",
    "require": {
        "php": "^8.2",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7",
        "firebase/php-jwt": "^6.9",
        "robthree/twofactorauth": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "audit": {
            "block-insecure": false
        }
    }
}